# ──────────────────────────────────────────────────────────────────────────────
# ShopFlow — Environment Variables
#
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in values from each provider's dashboard (links below).
# 3. VITE_ prefix  → exposed to the browser bundle (safe for public keys only).
#    No prefix      → server-side only, NEVER sent to the browser.
# ──────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed site — used for og:url and canonical link tags.
# In development this is usually http://localhost:5173
VITE_SITE_URL=https://shopflow.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API

# Project URL (client-safe)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key (client-safe — RLS enforces access control)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Project URL for the serverless API (can be the same as VITE_SUPABASE_URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key — NEVER expose to the browser. Used server-side only
# to validate product prices and bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys  (https://dashboard.stripe.com/apikeys)

# Publishable key (client-safe) — used if you add Stripe.js / Elements later
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key — NEVER expose to the browser. Used only in api/checkout.js
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — for verifying Stripe webhook events (optional)
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
