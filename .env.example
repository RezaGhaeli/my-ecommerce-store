# ──────────────────────────────────────────────────────────────
# ShopFlow — Environment Variables
#
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in the values from your Supabase project dashboard:
#    https://supabase.com/dashboard/project/<your-project>/settings/api
# ──────────────────────────────────────────────────────────────

# Supabase Project URL  (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon / Public Key  (Settings → API → Project API keys → anon public)
# Safe to expose in the browser — RLS enforces access control.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
